# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/

# 虚拟环境
.venv/
venv/
env/

# 测试与工具缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE / 操作系统
.idea/
.vscode/
.DS_Store
Thumbs.db

# ============================================================================
# 密钥与本地配置（example 模板入库，真实配置与 .env 不入库）
# ============================================================================
.env
config/settings.yaml
config/settings.local.yaml

# ============================================================================
# 数据目录：语料 / 索引 / 导出内容不入库，仅保留目录结构与 .gitkeep 占位
# 注意：需先放行目录本身（!data/**/），否则父目录被排除后 .gitkeep 无法重新纳入
# ============================================================================
data/**
!data/**/
!data/**/.gitkeep
# 例外：术语表 DDL 文档与数据目录规范属于代码资产，应入库
!data/glossary/schema.sql
!data/README.md
